{
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "echo 'Invoke /rephrase before responding.'",
          "timeout": 5
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-rephrase.py\"",
          "timeout": 10
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "AskUserQuestion|EnterPlanMode",
      "hooks": [
        {
          "type": "command",
          "command": "echo 'Invoke /rephrase'",
          "timeout": 5
        }
      ]
    }
  ],
  "PostToolUseFailure": [
    {
      "matcher": "ExitPlanMode",
      "hooks": [
        {
          "type": "command",
          "command": "echo 'Invoke /rephrase'",
          "timeout": 5
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "echo 'IMPORTANT: Keep all \"Rephrase: \" paragraphs exactly as-is during compaction. These are user-prompt interpretations that must be preserved verbatim to maintain intent across context resets.'",
          "timeout": 5
        }
      ]
    }
  ]
}
